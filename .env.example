# Copia para .env (na raiz) e ajusta os valores. O Docker Compose usa este ficheiro como .env
# por defeito para interpolar variáveis no docker-compose.yml (serviço api).
#
# MONGO_URL: na tua máquina (yarn migrate:up, yarn start:dev) usa localhost:27017.
# Dentro do contentor da api o compose define MONGO_URL para o host mongo (ver docker-compose.yml).

MONGO_URL=mongodb://localhost:27017/techChallenge
## MONGO_URL_INTEGRATION=mongodb://localhost:27017/outro-banco

JWT_SECRET=altere-este-segredo
JWT_EXPIRES_IN=1d
PORT=3000
SEED_ADMIN_EMAIL=admin@local.dev
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin
